{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "genieacs": { "type": "remote", "url": "http://192.168.1.111:8001/mcp", "timeout": 30000 },
    "olt": { "type": "remote", "url": "http://192.168.1.111:8002/mcp", "timeout": 30000 },
    "databases": { "type": "remote", "url": "http://192.168.1.111:8003/mcp", "timeout": 30000 }
  },
  "permission": {
    "bash": "deny",
    "edit": "deny",
    "read": "deny",
    "search": "deny",
